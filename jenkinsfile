pipeline{
    agent any
    options {
        retry(2)
    }
    tools{
        jdk 'Java11'
        maven 'Maven'
    }
    environment{
        SERVER_IP = '10.48.17.165'
    }
    stages{
        stage('Download the git repositories'){
            steps{
                dir('todo-api'){
                    git url:"https://github.com/pelthepu/todo-api.git", branch: 'master'
                }
                dir('todo-ui'){
                    git url:"https://github.com/pelthepu/todo-ui.git", branch: 'master'
                }
            }
        }
        stage('Build todo-api'){
            steps{
                dir('todo-api'){
                    sh 'mvn clean package -DskipTests'
                }
            }
        }
        stage('Sonar Qube Analysis'){
            steps{
                dir('todo-api'){
                    withEnv([
                    "JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64",
                    "PATH=/usr/lib/jvm/java-21-openjdk-amd64/bin:${env.PATH}"
                    ]){
                        withSonarQubeEnv ('SonarQube'){
                        sh '''
                            mvn sonar:sonar\
                            -Dsonar.projectKey=todo-project\
                            -Dsonar.projectName='todo project'\
                            -Dsonar.java.binaries=target/classes\
                            --batch-mode
                        '''
                        }
                    }
                }
            }
        }
        stage('upload to jfrog'){
            steps{
                dir('todo-api'){
                    script {

                        // Get version
                        def version = sh(
                            script: """
                                mvn help:evaluate \
                                -Dexpression=project.version \
                                -q \
                                -DforceStdout
                            """,
                            returnStdout: true
                        ).trim()

                        // Get artifactId (better than hardcoding appName)
                        def appName = sh(
                            script: """
                                mvn help:evaluate \
                                -Dexpression=project.artifactId \
                                -q \
                                -DforceStdout
                            """,
                            returnStdout: true
                        ).trim()

                        // Get actual jar file
                        def jarFile = sh(
                            script: "ls target/*.jar | head -n 1",
                            returnStdout: true
                        ).trim()

                        sh "ls -lh ${jarFile}"

                        withCredentials([usernamePassword(
                            credentialsId: 'jfrog-credentials',
                            usernameVariable: 'JFROG_USER',
                            passwordVariable: 'JFROG_PASS'
                        )]){

                            def jfrogUrl  = "http://${SERVER_IP}:30082/artifactory"
                            def repo      = "libs-release-local"

                            // Use actual jar filename
                            def fileName = jarFile.tokenize('/').last()

                            def destPath  = "${repo}/${appName}/${version}/${fileName}"

                            sh """
                                curl \
                                    -u ${JFROG_USER}:${JFROG_PASS} \
                                    -T ${jarFile} \
                                    -X PUT \
                                    "${jfrogUrl}/${destPath}"
                            """

                            echo "✅ Successfully uploaded to: ${jfrogUrl}/${destPath}"
                        }
                    }
                }
            }
        }
        stage('Deploy todo-api'){
            steps {
                dir('todo-api'){
                    sh '''
                        if [ -f ~/todo-api/api.pid ]; then
                            kill $(cat ~/todo-api/api.pid) 2>/dev/null || true
                            rm -f ~/todo-api/api.pid
                        fi

                        cd ~/todo-api

                        JAR=$(ls target/*.jar | head -n 1)

                        echo "Using JAR: $JAR"

                        nohup java -jar $JAR > ~/todo-api/api.log 2>&1 &

                        echo $! > ~/todo-api/api.pid
                        echo "✅ API started with PID $(cat ~/todo-api/api.pid)"
                    '''
                }
            }
        }
        stage('Deploy todo-ui'){
            steps {
                sh """
                    if [ -f ~/todo-ui.pid ]; then
                        kill \$(cat ~/todo-ui.pid) 2>/dev/null || true
                        rm -f ~/todo-ui.pid
                    fi
                    cd ~/todo-ui
                    echo "REACT_APP_BACKEND_SERVER_URL=http://${SERVER_IP}:8080" > .env
                    npm install --legacy-peer-deps
                    nohup npm start > ~/todo-ui.log 2>&1 &
                    echo \$! > ~/todo-ui.pid
                    echo "✅ UI started with PID \$(cat ~/todo-ui.pid)"
                """
            }
        }
    }
}